---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__content">
      <div class="footer__about">
        <p class="footer__name">The Humanitarian Commons</p>
        <p class="footer__tagline">Curated knowledge for understanding humanitarian action, contexts, and systems.</p>
      </div>
      <div class="footer__links">
        <a href="/about/">About</a>
        <a href="/topics/">Topics</a>
        <a href="/people/">People</a>
        <a href="/organizations/">Organizations</a>
        <a href="/library/">Library</a>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; {year} The Humanitarian Commons. Content is provided for educational and informational purposes.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-text);
    color: var(--color-bg);
    padding: var(--space-3xl) 0 var(--space-xl);
    margin-top: var(--space-4xl);
  }

  .footer__content {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }

  .footer__name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: var(--space-sm);
  }

  .footer__tagline {
    color: rgba(255,255,255,0.6);
    font-size: 0.9rem;
    max-width: 400px;
    margin-bottom: 0;
  }

  .footer__links {
    display: flex;
    gap: var(--space-lg);
  }

  .footer__links a {
    color: rgba(255,255,255,0.7);
    font-family: var(--font-heading);
    font-size: 0.9rem;
    text-decoration: none;
  }

  .footer__links a:hover {
    color: white;
    text-decoration: none;
  }

  .footer__bottom {
    padding-top: var(--space-lg);
  }

  .footer__bottom p {
    color: rgba(255,255,255,0.4);
    font-size: 0.8rem;
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .footer__content {
      flex-direction: column;
      gap: var(--space-lg);
    }

    .footer__links {
      flex-wrap: wrap;
      gap: var(--space-md);
    }
  }
</style>