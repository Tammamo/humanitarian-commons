---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Only show practitioners on the People listing page; authors/academics appear through Library pages
const people = (await getCollection('people'))
  .filter(p => !p.data.draft && p.data.category === 'practitioner')
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout title="People" description="Key people in humanitarian contexts and systems.">
  <section class="page-header">
    <div class="container container--narrow">
      <h1>People</h1>
      <p>Key individuals whose work, leadership, and expertise shape humanitarian action and debate.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--3">
        {people.map(person => (
          <a href={`/people/${person.id}/`} class="person-card">
            <div class="person-card__avatar">
              {person.data.photo ? (
                <img src={person.data.photo} alt={person.data.name} />
              ) : (
                <span class="person-card__initials">
                  {person.data.name.split(' ').map(n => n[0]).join('')}
                </span>
              )}
            </div>
            <h3 class="person-card__name">{person.data.name}</h3>
            {person.data.title && <p class="person-card__title">{person.data.title}</p>}
            {person.data.organization && <p class="person-card__org">{person.data.organization}</p>}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-3xl) 0 var(--space-xl);
  }

  .page-header h1 { margin-bottom: var(--space-md); }
  .page-header p { color: var(--color-text-secondary); font-size: 1.05rem; line-height: 1.7; }

  .person-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .person-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .person-card__avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    margin-bottom: var(--space-md);
    background: var(--color-accent-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .person-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .person-card__initials {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--color-accent);
  }

  .person-card__name {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .person-card__title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .person-card__org {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }
</style>